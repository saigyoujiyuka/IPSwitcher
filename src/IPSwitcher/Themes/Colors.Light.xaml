<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="LightBg">#F3F3F3</Color>
    <Color x:Key="LightCardBg">#FBFBFB</Color>
    <Color x:Key="LightCardBgAlt">#F0F0F0</Color>
    <Color x:Key="LightText">#1A1A1A</Color>
    <Color x:Key="LightTextSecondary">#6B6B6B</Color>
    <Color x:Key="LightBorder">#E0E0E0</Color>
    <Color x:Key="LightAccent">#0078D4</Color>
    <Color x:Key="LightAccentHover">#1A86D9</Color>
    <Color x:Key="LightAccentPressed">#005A9E</Color>
    <Color x:Key="LightDanger">#C42B1C</Color>
    <Color x:Key="LightSuccess">#107C10</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource LightBg}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource LightCardBg}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource LightCardBgAlt}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource LightText}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource LightTextSecondary}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource LightBorder}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource LightAccent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource LightAccentHover}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource LightAccentPressed}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource LightDanger}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource LightSuccess}"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="ControlBackgroundHoverBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ControlBackgroundPressedBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="ItemSelectedBackgroundBrush" Color="#CCE4F7"/>
    <SolidColorBrush x:Key="ItemSelectedHoverBackgroundBrush" Color="#B8D6EF"/>
</ResourceDictionary>

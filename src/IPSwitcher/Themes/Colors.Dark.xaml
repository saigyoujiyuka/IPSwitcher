<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="DarkBg">#1F1F1F</Color>
    <Color x:Key="DarkCardBg">#2B2B2B</Color>
    <Color x:Key="DarkCardBgAlt">#333333</Color>
    <Color x:Key="DarkText">#F0F0F0</Color>
    <Color x:Key="DarkTextSecondary">#9A9A9A</Color>
    <Color x:Key="DarkBorder">#3F3F3F</Color>
    <Color x:Key="DarkAccent">#4CC2FF</Color>
    <Color x:Key="DarkAccentHover">#69D0FF</Color>
    <Color x:Key="DarkAccentPressed">#29A8E8</Color>
    <Color x:Key="DarkDanger">#FF6E5C</Color>
    <Color x:Key="DarkSuccess">#6FCE6F</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource DarkBg}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource DarkCardBg}"/>
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="{StaticResource DarkCardBgAlt}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource DarkText}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource DarkTextSecondary}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource DarkBorder}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource DarkAccent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource DarkAccentHover}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource DarkAccentPressed}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DarkDanger}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource DarkSuccess}"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#383838"/>
    <SolidColorBrush x:Key="ControlBackgroundHoverBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="ControlBackgroundPressedBrush" Color="#424242"/>
    <SolidColorBrush x:Key="ItemSelectedBackgroundBrush" Color="#2D4A5E"/>
    <SolidColorBrush x:Key="ItemSelectedHoverBackgroundBrush" Color="#345467"/>
</ResourceDictionary>
